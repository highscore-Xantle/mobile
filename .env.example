# Copy to ".env" and fill in from your Supabase project (Settings -> API).
# EXPO_PUBLIC_ vars are readable in the app at runtime.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Cloudinary — create an unsigned upload preset in your Cloudinary dashboard
# (Settings → Upload → Upload presets → Add upload preset → Unsigned).
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
